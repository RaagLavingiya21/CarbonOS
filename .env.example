# Anthropic
ANTHROPIC_API_KEY=

# Frontend (CORS — set to deployed Next.js URL in production)
FRONTEND_URL=

# LangSmith tracing (auto-traces LangGraph runs when enabled)
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=carbon-footprint-analyzer
LANGSMITH_API_KEY=

# Supabase (Phase 3)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# UUID of the shared demo org (e.g. Aspire Inc.) — new users auto-join on first login
DEMO_ORG_ID=
# Optional: use JWT secret instead of JWKS for token verification
SUPABASE_JWT_SECRET=
# LangGraph PostgresSaver — paste ONLY the URI below (no comments on the same line).
# Supabase → Project Settings → Database → Connection string → URI (port 5432).
# Example shape: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=
